{
  "name": "hbp/disabler",
  "description": "Instead of installing million plugins to turn off features you don't want, why not use just ONE plugin?",
  "license": "GPL-2.0-or-later",
  "type": "wordpress-plugin",
  "keywords": [
    "wordpress"
  ],
  "authors": [
    {
      "name": "Hybopress Themes",
      "email": "support@hybopressthemes.com",
      "homepage": "https://wordpress.org/plugins/disabler/"
    }
  ],
  "homepage": "https://github.com/saas786/disabler",
  "support": {
    "issues": "https://github.com/saas786/disabler/issues",
    "forum": "https://wordpress.org/support/plugin/disabler",
    "wiki": "https://github.com/saas786/disabler/wiki",
    "source": "https://github.com/saas786/disabler"
  },
  "require": {
    "php": ">=8.2",
    "composer/installers": "^1.12 || ^2.0",
    "saas786/php-scoper-wp-excludes": "dev-main",
    "themehybrid/hybrid-action-scheduler": "^1.0",
    "themehybrid/hybrid-assets": "^1.0",
    "themehybrid/hybrid-contracts": "^2.0",
    "themehybrid/hybrid-core": "^7.0",
    "themehybrid/hybrid-events": "^1.0",
    "themehybrid/hybrid-filesystem": "^1.0",
    "themehybrid/hybrid-log": "^1.0",
    "themehybrid/hybrid-tools": "^2.0",
    "themehybrid/hybrid-usage-tracker": "^1.0",
    "themehybrid/hybrid-view": "^2.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "themehybrid/hybrid-dev-tools": "^1.0",
    "themehybrid/hybrid-phpcs-rules": "^1.0"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/saas786/hybrid-usage-tracker"
    },
    {
      "type": "vcs",
      "url": "https://github.com/saas786/php-scoper-wp-excludes"
    },
    {
      "type": "vcs",
      "url": "https://github.com/themehybrid/hybrid-dev-tools"
    },
    {
      "type": "vcs",
      "url": "https://github.com/themehybrid/hybrid-phpcs-rules"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "HBP\\Disabler\\": "inc/"
    }
  },
  "autoload-dev": {
    "classmap": [
      "bin-dev/"
    ]
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2"
    },
    "prepend-autoloader": false,
    "process-timeout": 0
  },
  "extra": {
    "hybrid-dev-tools": {
      "bin-path": "./bin-dev/tools",
      "configs-path": "./bin-dev/tools/configs",
      "overwrite-configs": false
    },
    "installer-paths": {
      "vendor/woocommerce/action-scheduler/": [
        "woocommerce/action-scheduler"
      ]
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@download-tools"
    ],
    "post-update-cmd": [
      "@download-tools"
    ],
    "analyze": [
      "@pint:analyze",
      "@psalm:analyze",
      "@phpcs:analyze"
    ],
    "composer:post:prefix": "composer dump-autoload --working-dir disabler-prefixed --classmap-authoritative",
    "composer:pre:prefix": "composer install --no-dev --prefer-dist --no-scripts",
    "composer:reset": "composer install --no-scripts",
    "download-tools": "Hybrid\\DevTools\\Composer\\Actions::downloadTools",
    "lint:syntax": "@php ./vendor/bin/parallel-lint ./bin-dev/php-scoper ./config ./inc ./public/views ./disabler.php --show-deprecated -e php --exclude assets",
    "lint:syntax:prefixed": "@php ./bin-dev/tools/parallel-lint.phar ./disabler-prefixed/config ./disabler-prefixed/inc ./disabler-prefixed/public/views ./disabler-prefixed/disabler.php --show-deprecated -e php",
    "phpcs:analyze": "@php ./vendor/bin/phpcs ./bin-dev/php-scoper ./config ./inc ./public/views ./disabler.php",
    "phpcs:fix": "@php ./vendor/bin/phpcbf ./bin-dev/php-scoper ./config ./inc ./public/views ./disabler.php",
    "pint:analyze": "@php ./bin-dev/tools/pint.phar ./bin-dev/php-scoper ./config ./inc ./public/views ./disabler.php --config ./bin-dev/tools/configs/pint.json --test",
    "pint:analyze:prefixed": "@php ./bin-dev/tools/pint.phar ./disabler-prefixed/config ./disabler-prefixed/inc ./disabler-prefixed/public/views ./disabler-prefixed/disabler.php --config ./bin-dev/tools/configs/pint.json --test",
    "pint:fix": "@php ./bin-dev/tools/pint.phar ./bin-dev/php-scoper ./config ./inc ./public/views ./disabler.php --config ./bin-dev/tools/configs/pint.json",
    "pint:fix:prefixed": "@php ./bin-dev/tools/pint.phar ./disabler-prefixed/config ./disabler-prefixed/inc ./disabler-prefixed/public/views ./disabler-prefixed/disabler.php --config ./bin-dev/tools/configs/pint.json",
    "prefix": [
      "rm -rf disabler-prefixed",
      "@composer:pre:prefix",
      "@php -d memory_limit=-1 ./bin-dev/tools/php-scoper.phar add-prefix --config ./bin-dev/php-scoper/scoper.inc.php --output-dir disabler-prefixed --force --quiet --ansi",
      "@pint:fix:prefixed",
      "@composer:post:prefix",
      "rm disabler-prefixed/composer.json",
      "@php ./bin-dev/php-scoper/fix-static-file-autoloader.php disabler-prefixed/vendor/composer || die \"Failed to scope theme\"",
      "@composer:reset"
    ],
    "psalm:analyze": "@php ./bin-dev/tools/psalm.phar --config=./psalm.xml",
    "psalm:fix": "@php ./bin-dev/tools/psalm.phar --alter --config=./psalm.xml --issues=all"
  }
}
