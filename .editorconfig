# This file is for unifying the coding style for different editors and IDEs
# editorconfig.org

# WordPress Coding Standards
# https://make.wordpress.org/core/handbook/best-practices/coding-standards/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab

[{*.css,*.scss}]
indent_style = space
indent_size = 2

[{.babelrc,.browserslistrc}]
indent_size = unset
indent_style = space

[{package.json,composer.json}]
indent_style = space
indent_size = unset

# need to configure it in eslint.config.js as well, as default rules force space with 2 size
[{src/styles/**/*.json,src/theme.json}]
indent_style = tab

[*.xml]
indent_style = space
indent_size = 4

[*.txt]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false

[*.php]
indent_style = space
indent_size = 4

[composer.json]
indent_size = 4

[{*.js,*.mjs,eslint.config.js}]
indent_style = space
indent_size = 2
